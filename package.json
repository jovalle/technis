{
  "name": "technis",
  "version": "2.0.0",
  "private": true,
  "description": "Home(lab) planet of sorts",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "fmt": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,html,css,scss,yaml,yml}\"",
    "fmt:json": "prettier --write \"**/*.json\"",
    "fmt:yaml": "prettier --write \"**/*.{yaml,yml}\"",
    "fmt:toml": "taplo fmt",
    "lint:json": "fixjson -q -w .",
    "lint:toml": "taplo check"
  },
  "devDependencies": {
    "@taplo/cli": "^0.7.0",
    "fixjson": "^1.0.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
